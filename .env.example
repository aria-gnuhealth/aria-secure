# ------------------------------------------------------------
# ARIA-Core Environment Variables (TEMPLATE)
# Copier ce fichier en .env et remplir les valeurs
# ------------------------------------------------------------

POSTGRES_SERVER=postgres
POSTGRES_USER=aria_user
POSTGRES_PASSWORD=change_me
POSTGRES_DB=aria_db
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_SERVER}:5432/${POSTGRES_DB}

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}

MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=change_me
MINIO_SECRET_KEY=change_me
MINIO_BUCKET=aria-dicom

# Générer avec : python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=change_me_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30

ONNX_MODEL_PATH=ml/models/aria_densenet121_v1.onnx
ONNX_PROVIDERS=CPUExecutionProvider

GH_API_URL=http://gnuhealth-server:8000/api/fhir
GH_CLIENT_ID=aria_module
GH_CLIENT_SECRET=change_me_gnuhealth

ENVIRONMENT=development
LOG_LEVEL=INFO